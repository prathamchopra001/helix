{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Prediction Volume",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "postgres", "uid": "postgres"},
      "targets": [
        {
          "rawSql": "SELECT DATE(created_at) as time, COUNT(*) as predictions FROM predictions.inference_log GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "displayName": "Predictions"
        }
      },
      "options": {
        "tooltip": {"mode": "single"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    },
    {
      "id": 2,
      "title": "Anomaly Rate (7d %)",
      "type": "stat",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "postgres", "uid": "postgres"},
      "targets": [
        {
          "rawSql": "SELECT ROUND(100.0*SUM(label)/COUNT(*), 2) FROM predictions.inference_log WHERE created_at > NOW() - INTERVAL '7 days'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 15}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "F1 Score (7d)",
      "type": "stat",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "postgres", "uid": "postgres"},
      "targets": [
        {
          "rawSql": "SELECT metric_value FROM monitoring.model_metrics WHERE metric_name='f1' AND window_days=7 ORDER BY computed_at DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.6},
              {"color": "green", "value": 0.75}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Avg Latency (24h)",
      "type": "stat",
      "gridPos": {"x": 12, "y": 4, "w": 6, "h": 4},
      "datasource": {"type": "postgres", "uid": "postgres"},
      "targets": [
        {
          "rawSql": "SELECT ROUND(AVG(latency_ms)::numeric, 2) FROM predictions.inference_log WHERE created_at > NOW() - INTERVAL '24 hours'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 100},
              {"color": "red", "value": 500}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "title": "Model Version",
      "type": "stat",
      "gridPos": {"x": 18, "y": 4, "w": 6, "h": 4},
      "datasource": {"type": "postgres", "uid": "postgres"},
      "targets": [
        {
          "rawSql": "SELECT model_version, COUNT(*) as predictions FROM predictions.inference_log GROUP BY model_version ORDER BY 2 DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "string"
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "/^model_version$/"},
        "orientation": "auto",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 6,
      "title": "Avg Score Over Time",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 8, "w": 24, "h": 8},
      "datasource": {"type": "postgres", "uid": "postgres"},
      "targets": [
        {
          "rawSql": "SELECT DATE(created_at) as time, AVG(score) as avg_score FROM predictions.inference_log GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "displayName": "Avg Score",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 0.5}
            ]
          }
        }
      },
      "options": {
        "tooltip": {"mode": "single"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "tags": ["helix", "model"],
  "templating": {"list": []},
  "time": {"from": "now-7d", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Model KPIs",
  "uid": "helix-model-kpis",
  "version": 1
}
