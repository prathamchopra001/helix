# -----------------------------------------------------------------------------
  # PostgreSQL
  # -----------------------------------------------------------------------------
  POSTGRES_HOST=postgres
  POSTGRES_PORT=5432
  POSTGRES_DB=helix
  POSTGRES_USER=helix
  POSTGRES_PASSWORD=changeme

  # Full async DSN (used by SQLAlchemy in all services)
  DATABASE_URL=postgresql+asyncpg://helix:changeme@postgres:5432/helix

  # -----------------------------------------------------------------------------
  # MinIO (S3-compatible object storage)
  # -----------------------------------------------------------------------------
  MINIO_ENDPOINT=minio:9000
  MINIO_ACCESS_KEY=minioadmin
  MINIO_SECRET_KEY=minioadmin
  MINIO_SECURE=false

  # Bucket names
  MINIO_BUCKET_RAW=raw-data
  MINIO_BUCKET_MODELS=models
  MINIO_BUCKET_MLFLOW=mlflow-artifacts

  # -----------------------------------------------------------------------------
  # Redis (Airflow Celery broker + result backend)
  # -----------------------------------------------------------------------------
  REDIS_HOST=redis
  REDIS_PORT=6379
  REDIS_URL=redis://redis:6379/0

  # -----------------------------------------------------------------------------
  # MLflow
  # -----------------------------------------------------------------------------
  MLFLOW_TRACKING_URI=http://mlflow:5000
  MLFLOW_S3_ENDPOINT_URL=http://minio:9000
  AWS_ACCESS_KEY_ID=minioadmin
  AWS_SECRET_ACCESS_KEY=minioadmin

  # -----------------------------------------------------------------------------
  # Airflow
  # -----------------------------------------------------------------------------
  AIRFLOW__CORE__EXECUTOR=CeleryExecutor
  AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://helix:changeme@postgres:5432/helix
  AIRFLOW__CELERY__BROKER_URL=redis://redis:6379/0
  AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://helix:changeme@postgres:5432/helix
  AIRFLOW__CORE__FERNET_KEY=changeme_generate_with_python_-c_"from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
  AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
  AIRFLOW__CORE__MAX_ACTIVE_RUNS_PER_DAG=1
  AIRFLOW__WEBSERVER__SECRET_KEY=changeme
  AIRFLOW_ADMIN_USER=admin
  AIRFLOW_ADMIN_PASSWORD=admin

  # -----------------------------------------------------------------------------
  # Inference API
  # -----------------------------------------------------------------------------
  API_KEYS=dev-key-1,dev-key-2
  INFERENCE_BACKEND=pytorch
  # Options: tensorrt | onnx | pytorch

  # -----------------------------------------------------------------------------
  # Grafana
  # -----------------------------------------------------------------------------
  GF_SECURITY_ADMIN_USER=admin
  GF_SECURITY_ADMIN_PASSWORD=admin

  # -----------------------------------------------------------------------------
  # Feature flags
  # -----------------------------------------------------------------------------
  ANOMALY_Z_SCORE_THRESHOLD=2.5
  ANOMALY_VOLUME_RATIO_THRESHOLD=2.0
  DRIFT_PSI_THRESHOLD=0.2
  DRIFT_FEATURE_COUNT_THRESHOLD=3
  RETRAINING_F1_IMPROVEMENT_THRESHOLD=0.02